# Copy this file to ".env" and paste your real key in.
# The real .env is git-ignored, so your key is never uploaded.

# --- Which answer-writer to use: groq (free, default) | claude | ollama ---
LLM_BACKEND=groq

# --- Groq (FREE): get a key at https://console.groq.com  (no card needed) ---
GROQ_API_KEY=gsk_your-groq-key-here

# --- Claude (optional, paid): only needed if LLM_BACKEND=claude ---
# ANTHROPIC_API_KEY=sk-ant-your-key-here
